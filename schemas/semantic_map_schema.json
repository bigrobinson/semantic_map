{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SemanticMapSchema",
  "type": "object",
  "required": ["map_info", "regions", "polygons"],
  "properties": {
    "map_info": {
      "type": "object",
      "required": ["contributor", "date_created", "description", "map_url", "json_url", "version", "width", "height"],
      "properties": {
        "contributor": { "type": "string" },
        "date_created": { "type": "string" },
        "description": { "type": "string" },
        "map_url": { "type": "string" },
        "json_url": { "type": "string" },
        "version": { "type": "string" },
        "width": { "type": "integer" },
        "height": { "type": "integer" }
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "polygon_ids", "superregions", "subregions", "strings"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "polygon_ids": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "superregions": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "subregions": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "strings": {
            "type": "array",
            "items": { "$ref": "#/definitions/StringDoc" }
          }
        }
      }
    },
    "polygons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "region_ids", "polygon", "polygon_centroid", "strings", "images"],
        "properties": {
          "id": { "type": "integer" },
          "region_ids": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "polygon": {
            "type": "array",
            "items": { "type": "number" }
          },
          "polygon_centroid": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          },
          "strings": {
            "type": "array",
            "items": { "$ref": "#/definitions/StringDoc" }
          },
          "images": {
            "type": "array",
            "items": { "$ref": "#/definitions/ImageDoc" }
          }
        }
      }
    }
  },
  "definitions": {
    "StringDoc": {
      "type": "object",
      "required": ["string", "embedding"],
      "properties": {
        "string": { "type": "string" },
        "embedding": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    },
    "ImageDoc": {
      "type": "object",
      "required": ["image_url", "description", "description_embedding", "width", "height", "embedding"],
      "properties": {
        "image_url": { "type": "string" },
        "description": { "type": "string" },
        "description_embedding": {
          "type": "array",
          "items": { "type": "number" }
        },
        "width": { "type": "integer" },
        "height": { "type": "integer" },
        "embedding": {
          "type": "array",
          "items": { "type": "number" }
        }
      }
    }
  }
}
